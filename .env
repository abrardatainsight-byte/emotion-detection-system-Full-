# Backend settings
ALLOWED_ORIGINS=*
# Optional: database URL for production, e.g. postgres://user:pass@host:5432/dbname
DATABASE_URL= "sqlite:///./emotion_system.db"

# Optional: override default Hugging Face model name
EMOTION_MODEL_NAME=dima806/facial_emotions_image_detection

# Frontend setting (Vite requires VITE_ prefix)
VITE_API_URL=http://127.0.0.1:8000
